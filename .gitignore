# vite.config.ts source siempre OK; ignoramos salidas tsc accidentales
apps/*/vite.config.js
apps/*/vite.config.d.ts

# --- secretos / envs (mantén los .example) ---
.env
.env.*
!.env.example
apps/*/.env
apps/*/.env.*
!apps/*/.env.example
*.pem
*.key
*.secret

# --- Python (en cualquier carpeta) ---
**/__pycache__/
**/*.py[cod]
**/*.pyo
**/*.egg-info/
**/.cache/
**/.coverage*
**/.venv/
.venv/
r/

# --- Node / TS (en cualquier carpeta) ---
**/node_modules/
**/dist/
**/build/
**/*.tsbuildinfo
**/.eslintcache
**/*.map

# --- datos locales / dumps ---
postgres-data/
db-data/
*.dump
*.tar
*.zip
src.zip

# Ignorar .sql por defecto (dumps), PERO permitir migraciones/scripts versionados
*.sql
!ops/migrations/**/*.sql
!ops/scripts/**/*.sql
!ops/sql/**/*.sql

